# ============================================
# EstateIQ Server - Environment Configuration
# ============================================

# Server Port
PORT=5000

# Node Environment (development / production)
NODE_ENV=development

# MongoDB Connection String
# For local: mongodb://localhost:27017/estateiq
# For Atlas: mongodb+srv://<user>:<pass>@cluster0.xxxxx.mongodb.net/estateiq
MONGO_URI=mongodb://localhost:27017/estateiq

# JWT Secret Key (use a strong random string in production!)
JWT_SECRET=your_jwt_secret_key_change_me_in_production

# Frontend URL (comma-separated for multiple origins)
# On Render, set this to your Vercel frontend URL
CLIENT_URL=http://localhost:5173

# SMTP Email Configuration (optional — for email notifications)
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your-email@gmail.com
# SMTP_PASS=your-app-password
# FROM_NAME=EstateIQ
# FROM_EMAIL=noreply@estateiq.com
